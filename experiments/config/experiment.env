: "${EXPERIMENT_CPU_CORE:=2}"
: "${EXPERIMENT_REPEATS:=30}"
: "${EXPERIMENT_EVENTS_PER_RUN:=10000}"
: "${EXPERIMENT_WARMUP_RUNS:=3}"
: "${EXPERIMENT_RESULT_BASE:=experiments/results}"
: "${MCP_GUARD_POLICY_DIR:=policies}"
: "${EXPERIMENT_SOCKET_PORT:=4444}"
: "${EXPERIMENT_TASKSET:=taskset}"
: "${EXPERIMENT_TIME:=/usr/bin/time}"
: "${EXPERIMENT_TMP_BASE:=/tmp}"
: "${EXPERIMENT_METRICS_INTERVAL:=0}"
: "${EXPERIMENT_RUN_TIMEOUT_SEC:=120}"
